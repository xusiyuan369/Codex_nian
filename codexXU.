#!/usr/bin/env node
import { execFileSync } from "node:child_process";
import fs from "node:fs";
import crypto from "node:crypto";
import net from "node:net";
import os from "node:os";
import path from "node:path";
import { createRequire } from "node:module";
import readline from "node:readline/promises";

const home = process.env.HOME || os.homedir();
const codexHome = process.env.CODEX_HOME || path.join(home, ".codex");
const binDir =
  process.env.XU_BIN_DIR ||
  (process.env.PREFIX ? path.join(process.env.PREFIX, "bin") : path.join(home, "bin"));
const chatProvidersPath =
  process.env.XU_CHAT_PROVIDERS_CONFIG ||
  process.env.CODEX_CHAT2RESP_CONFIG ||
  path.join(codexHome, "xu-chat-providers.json");

const embeddedTools = {
  proxy: "",
  catalog: "",
};
const isTty = Boolean(process.stdin.isTTY && process.stdout.isTTY);
const pipedText = isTty ? null : fs.readFileSync(0, "utf8");
const pipedAnswers = isTty
  ? null
  : (pipedText.includes("\\n") && !pipedText.includes("\n")
      ? pipedText.replaceAll("\\n", "\n")
      : pipedText
    ).split(/\r?\n/);
let pipedIndex = 0;
const rl = isTty
  ? readline.createInterface({
      input: process.stdin,
      output: process.stdout,
    })
  : null;
const BACK = Symbol("back");
const DEFAULT_SETTINGS = {
  context: 128000,
  output: 32768,
  timeoutSeconds: 60,
  maxRetries: 10,
};
const DEFAULT_PROXY_PORT = 57321;
const proxyPortPath = path.join(codexHome, "xu-proxy.sh");
const upstreamProxyPath = path.join(codexHome, "xu-upstream-proxy.sh");

function title(text) {
  console.log(`\n\x1b[1;36m${text}\x1b[0m`);
}

function info(text) {
  console.log(`\x1b[2m${text}\x1b[0m`);
}

function warn(text) {
  console.log(`\x1b[33m${text}\x1b[0m`);
}

function ok(text) {
  console.log(`\x1b[32m${text}\x1b[0m`);
}

function ensureDir(dir) {
  fs.mkdirSync(dir, { recursive: true });
}

function escapeToml(value) {
  return String(value).replace(/\\/g, "\\\\").replace(/"/g, '\\"');
}

function tomlString(value) {
  return `"${escapeToml(value)}"`;
}

function safeId(value) {
  const raw = String(value).trim();
  const id = raw
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9_]+/g, "_")
    .replace(/^_+|_+$/g, "");
  if (id) return id;
  const hash = crypto.createHash("sha256").update(raw || "provider").digest("hex").slice(0, 8);
  return `provider_${hash}`;
}

function envName(providerId) {
  return `XU_${providerId.toUpperCase().replace(/[^A-Z0-9]+/g, "_")}_API_KEY`;
}

function isBack(value) {
  return value === BACK;
}

function positiveInteger(value, fallback) {
  const parsed = Number(value);
  return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;
}

function validPort(value, fallback = DEFAULT_PROXY_PORT) {
  const parsed = Number(value);
  return Number.isInteger(parsed) && parsed >= 1024 && parsed <= 65535 ? parsed : fallback;
}

function readProxyPort() {
  const fallback = Number(process.env.CODEX_CHAT2RESP_PORT || DEFAULT_PROXY_PORT);
  if (!fs.existsSync(proxyPortPath)) return validPort(fallback);
  const text = fs.readFileSync(proxyPortPath, "utf8");
  const match = text.match(/CODEX_CHAT2RESP_PORT=(?:"([^"]+)"|'([^']+)'|([0-9]+))/);
  return validPort(match?.[1] || match?.[2] || match?.[3] || fallback);
}

function writeProxyPort(port) {
  writePrivate(proxyPortPath, `export CODEX_CHAT2RESP_PORT=${JSON.stringify(String(port))}\n`);
}

function parseShellExport(text, key) {
  const match = text.match(
    new RegExp(`(?:^|\\n)\\s*(?:export\\s+)?${key}=("([^"]*)"|'([^']*)'|([^\\n#]*))`),
  );
  return (match?.[2] ?? match?.[3] ?? match?.[4] ?? "").trim();
}

function currentUpstreamProxy() {
  if (!fs.existsSync(upstreamProxyPath)) {
    return {
      mode: currentProxyFromEnv() ? "proxy" : "env",
      url: currentProxyFromEnv(),
      configured: false,
    };
  }
  const text = fs.readFileSync(upstreamProxyPath, "utf8");
  const mode = parseShellExport(text, "XU_UPSTREAM_PROXY_MODE") || "env";
  const url =
    parseShellExport(text, "XU_UPSTREAM_PROXY_URL") ||
    parseShellExport(text, "HTTPS_PROXY") ||
    parseShellExport(text, "ALL_PROXY") ||
    parseShellExport(text, "HTTP_PROXY");
  return { mode, url, configured: true };
}

function currentProxyFromEnv() {
  return (
    process.env.HTTPS_PROXY ||
    process.env.https_proxy ||
    process.env.ALL_PROXY ||
    process.env.all_proxy ||
    process.env.HTTP_PROXY ||
    process.env.http_proxy ||
    ""
  );
}

function clearProxyEnv() {
  for (const key of ["HTTPS_PROXY", "https_proxy", "HTTP_PROXY", "http_proxy", "ALL_PROXY", "all_proxy"]) {
    delete process.env[key];
  }
}

function applySavedUpstreamProxy() {
  const config = currentUpstreamProxy();
  if (config.mode === "direct") {
    clearProxyEnv();
    return;
  }
  if (config.mode === "proxy" && config.url) {
    process.env.HTTPS_PROXY = config.url;
    process.env.HTTP_PROXY = config.url;
    process.env.ALL_PROXY = config.url;
  }
}

function writeUpstreamProxy(mode, url = "") {
  const lines = [`export XU_UPSTREAM_PROXY_MODE=${JSON.stringify(mode)}`];
  if (mode === "proxy") {
    lines.push(`export XU_UPSTREAM_PROXY_URL=${JSON.stringify(url)}`);
    lines.push(`export HTTPS_PROXY=${JSON.stringify(url)}`);
    lines.push(`export HTTP_PROXY=${JSON.stringify(url)}`);
    lines.push(`export ALL_PROXY=${JSON.stringify(url)}`);
  }
  writePrivate(upstreamProxyPath, `${lines.join("\n")}\n`);
  applySavedUpstreamProxy();
}

async function configureUpstreamProxy() {
  for (;;) {
    const current = currentUpstreamProxy();
    const summary =
      current.mode === "proxy" && current.url
        ? `当前: 代理 ${current.url}`
        : current.mode === "direct"
          ? "当前: 强制直连"
          : "当前: 跟随 Termux 环境变量";
    const value = await choose(
      "上游网络设置",
      [
        { label: "跟随 Termux 环境变量", value: "env", description: "读取当前 HTTPS_PROXY / ALL_PROXY；没有就直连。" },
        { label: "强制直连", value: "direct", description: "清掉代理变量，让 xu 和本地转发层直接请求供应商。" },
        { label: "使用代理地址", value: "proxy", description: "把代理地址保存给 xu 和本地转发层，例如 http://127.0.0.1:7890。" },
        { label: "返回", value: "back" },
      ],
      { note: `${summary}。Codex 只连 127.0.0.1，真正出网由本地转发层处理。` },
    );
    if (isBack(value) || value === "back") return BACK;
    if (value === "env") {
      if (fs.existsSync(upstreamProxyPath)) fs.rmSync(upstreamProxyPath, { force: true });
      applySavedUpstreamProxy();
      ok("已切换为跟随 Termux 环境变量。");
      return "env";
    }
    if (value === "direct") {
      writeUpstreamProxy("direct");
      ok("已切换为强制直连。");
      return "direct";
    }
    if (value === "proxy") {
      const fallback = current.url || "http://127.0.0.1:7890";
      const url = await ask("代理地址", fallback);
      if (isBack(url)) continue;
      if (!/^https?:\/\//i.test(url)) {
        warn("代理地址建议写成 http://host:port 或 https://host:port。");
        continue;
      }
      writeUpstreamProxy("proxy", url);
      ok(`已保存上游代理: ${url}`);
      return "proxy";
    }
  }
}

function isPortAvailable(port) {
  return new Promise((resolve) => {
    const server = net.createServer();
    server.once("error", () => resolve(false));
    server.once("listening", () => {
      server.close(() => resolve(true));
    });
    server.listen(port, "127.0.0.1");
  });
}

async function configureProxyPort({ forceAsk = false } = {}) {
  const existing = fs.existsSync(proxyPortPath);
  if (existing && !forceAsk) return readProxyPort();
  for (;;) {
    title("本地代理端口");
    info("Chat 转换和多供应商统一入口会在本机 127.0.0.1 监听这个端口。");
    const raw = await ask("端口", String(readProxyPort()));
    if (isBack(raw)) return BACK;
    const port = validPort(raw, 0);
    if (!port) {
      warn("端口需要是 1024-65535 之间的数字。");
      continue;
    }
    if (!(await isPortAvailable(port))) {
      warn(`端口 ${port} 已被占用，请换一个。`);
      continue;
    }
    writeProxyPort(port);
    ok(`端口 ${port} 可用，已保存。`);
    return port;
  }
}

function proxyBaseUrl(port = readProxyPort()) {
  return `http://127.0.0.1:${port}/v1`;
}

function clearScreen() {
  if (isTty) process.stdout.write("\x1b[2J\x1b[H");
}

function renderMenu(prompt, options, selectedIndex, help, checked = null, note = "") {
  clearScreen();
  console.log("\x1b[1;36mXuCodex\x1b[0m");
  console.log(`\n${prompt}\n`);
  if (note) console.log(`\x1b[2m${note}\x1b[0m\n`);
  options.forEach((option, index) => {
    const focused = index === selectedIndex;
