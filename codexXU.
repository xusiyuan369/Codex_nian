    const line = `${marker} ${option.label}`;
    console.log(focused ? `\x1b[7m ${line} \x1b[0m` : ` ${line}`);
    if (option.description) {
      console.log(`\x1b[2m    ${option.description}\x1b[0m`);
    }
  });
  console.log(`\n\x1b[2m${help}\x1b[0m`);
}

function cleanupRawInput(onData) {
  process.stdin.setRawMode(false);
  process.stdin.off("data", onData);
}

async function readLineRaw(prompt, fallback = "", { secret = false, allowBack = true } = {}) {
  const suffix = fallback ? ` [${fallback}]` : "";
  const label = `${prompt}${suffix}: `;
  process.stdout.write(label);
  process.stdin.setRawMode(true);
  process.stdin.resume();
  process.stdin.setEncoding("utf8");

  let value = "";
  const redraw = () => {
    const visible = secret ? "*".repeat([...value].length) : value;
    process.stdout.write(`\r\x1b[2K${label}${visible}`);
  };

  return new Promise((resolve) => {
    const finish = (result) => {
      cleanupRawInput(onData);
      process.stdout.write("\n");
      resolve(result);
    };
    const onData = (chunk) => {
      if (chunk === "\u0003") {
        process.stdout.write("\n");
        process.exit(130);
      }
      if (allowBack && chunk === "\u001b") {
        finish(BACK);
        return;
      }
      if (chunk.startsWith("\u001b")) return;

      for (const char of chunk) {
        if (char === "\r" || char === "\n") {
          finish(value.trim() || fallback);
          return;
        }
        if (char === "\u007f" || char === "\b") {
          value = [...value].slice(0, -1).join("");
          redraw();
          continue;
        }
        if (char >= " ") {
          value += char;
          redraw();
        }
      }
    };
    process.stdin.on("data", onData);
  });
}

async function ask(prompt, fallback = "", options = {}) {
  const suffix = fallback ? ` [${fallback}]` : "";
  if (pipedAnswers) {
    if (pipedIndex >= pipedAnswers.length) {
      console.log(`${prompt}${suffix}: <end>`);
      return BACK;
    }
    const raw = pipedAnswers[pipedIndex++] ?? "";
    const answer = raw.trim();
    console.log(`${prompt}${suffix}: ${answer ? "<provided>" : ""}`);
    return answer || fallback;
  }
  if (isTty && process.stdin.setRawMode) {
    return readLineRaw(prompt, fallback, options);
  }
  const answer = (await rl.question(`${prompt}${suffix}: `)).trim();
  return answer || fallback;
}

async function askSecret(prompt) {
  if (!isTty || !process.stdin.setRawMode) {
    return ask(prompt);
  }

  return readLineRaw(prompt, "", { secret: true, allowBack: true });
}

async function chooseInteractive(prompt, options, { backLabel = "Esc 返回", note = "" } = {}) {
  let selectedIndex = 0;
  for (;;) {
    renderMenu(prompt, options, selectedIndex, `Tab/↑↓ 切换 · Enter 确认 · ${backLabel}`, null, note);
    const key = await new Promise((resolve) => {
      process.stdin.setRawMode(true);
      process.stdin.resume();
      process.stdin.setEncoding("utf8");
      const onData = (chunk) => {
        cleanupRawInput(onData);
        resolve(chunk);
      };
      process.stdin.on("data", onData);
    });

    if (key === "\u0003") process.exit(130);
    if (key === "\t" || key === "\u001b[C" || key === "\u001b[B") {
      selectedIndex = (selectedIndex + 1) % options.length;
      continue;
    }
    if (key === "\u001b[D" || key === "\u001b[A") {
      selectedIndex = (selectedIndex - 1 + options.length) % options.length;
      continue;
    }
    if (key === "\r" || key === "\n") return options[selectedIndex].value;
    if (key === "\u001b") return BACK;
  }
}

async function choose(prompt, options, settings = {}) {
  if (isTty && process.stdin.setRawMode) {
    return chooseInteractive(prompt, options, settings);
  }

  console.log("");
  console.log(prompt);
  if (settings.note) console.log(`  ${settings.note}`);
  options.forEach((option, index) => {
    console.log(`  ${index + 1}. ${option.label}`);
  });
  for (;;) {
    const raw = await ask("请输入序号", "1");
    if (isBack(raw)) return BACK;
    const index = Number(raw) - 1;
    if (Number.isInteger(index) && options[index]) return options[index].value;
    warn("Invalid choice.");
  }
}

async function waitForConfirmOrAdvanced(settings) {
  const text =
    `确认写入配置\n\n` +
    `上下文长度: ${settings.context}\n` +
    `输出长度: ${settings.output}\n` +
    `请求超时: ${settings.timeoutSeconds}s\n` +
    `自动重试: ${settings.maxRetries} 次\n`;
  if (!isTty || !process.stdin.setRawMode) {
    console.log("");
    console.log(text);
    console.log("非交互模式使用默认高级设置。");
    return "confirm";
  }

  for (;;) {
    clearScreen();
    console.log("\x1b[1;36mXuCodex\x1b[0m");
    console.log(`\n${text}`);
    console.log("\x1b[2mEnter 保存 · Alt+A/A 高级设置 · Esc 返回上一层\x1b[0m");
    const key = await new Promise((resolve) => {
      process.stdin.setRawMode(true);
      process.stdin.resume();
      process.stdin.setEncoding("utf8");
      const onData = (chunk) => {
        cleanupRawInput(onData);
        resolve(chunk);
      };
      process.stdin.on("data", onData);
    });
    if (key === "\u0003") process.exit(130);
    if (key === "\r" || key === "\n") return "confirm";
    if (key === "\u001b") return BACK;
    if (key === "a" || key === "A" || key === "\u001ba" || key === "\u001bA") return "advanced";
  }
}

async function configureAdvancedSettings(current) {
  let settings = { ...current };
  for (;;) {
    title("高级设置");
    info("直接回车保留默认值；Esc 返回确认页。");
    const context = await ask("上下文长度", String(settings.context));
    if (isBack(context)) return BACK;
    settings.context = positiveInteger(context, settings.context);

    const output = await ask("输出长度", String(settings.output));
    if (isBack(output)) return BACK;
    settings.output = positiveInteger(output, settings.output);

    const timeout = await ask("请求超时秒数", String(settings.timeoutSeconds));
    if (isBack(timeout)) return BACK;
    settings.timeoutSeconds = positiveInteger(timeout, settings.timeoutSeconds);

    const retries = await ask("自动重试次数", String(settings.maxRetries));
    if (isBack(retries)) return BACK;
    settings.maxRetries = positiveInteger(retries, settings.maxRetries);

    return settings;
  }
}

async function chooseMany(prompt, options) {
  if (isTty && process.stdin.setRawMode) {
    const allOptions = [...options, { label: "手动输入", value: "__manual__" }];
    const checked = new Set();
    let selectedIndex = 0;
    for (;;) {
      renderMenu(
        prompt,
        allOptions,
        selectedIndex,
        "Tab/↑↓ 切换 · Space 勾选/取消 · Enter 确认 · Esc 返回",
        checked,
      );
      const key = await new Promise((resolve) => {
        process.stdin.setRawMode(true);
        process.stdin.resume();
        process.stdin.setEncoding("utf8");
        const onData = (chunk) => {
          cleanupRawInput(onData);
          resolve(chunk);
        };
        process.stdin.on("data", onData);
      });

      if (key === "\u0003") process.exit(130);
      if (key === "\t" || key === "\u001b[C" || key === "\u001b[B") {
        selectedIndex = (selectedIndex + 1) % allOptions.length;
        continue;
      }
      if (key === "\u001b[D" || key === "\u001b[A") {
        selectedIndex = (selectedIndex - 1 + allOptions.length) % allOptions.length;
        continue;
      }
      if (key === "\u001b") return BACK;
      if (key === " ") {
        if (selectedIndex < options.length) {
          if (checked.has(selectedIndex)) checked.delete(selectedIndex);
          else checked.add(selectedIndex);
        }
        continue;
      }
      if (key === "\r" || key === "\n") {
        if (selectedIndex === options.length) return [];
        const selected = checked.size ? [...checked].sort((a, b) => a - b) : [selectedIndex];
        return selected.map((index) => options[index].value);
      }
    }
  }

  console.log("");
  console.log(prompt);
  options.forEach((option, index) => {
    console.log(`  ${index + 1}. ${option.label}`);
  });
  console.log("  0. 手动输入");
  const raw = await ask("请输入序号，多个用英文逗号分隔", "1");
  if (raw === "0") return [];
  const selected = raw
    .split(",")
    .map((part) => Number(part.trim()) - 1)
    .filter((index) => Number.isInteger(index) && options[index])
    .map((index) => options[index].value);
  return [...new Set(selected)];
}

function endpointUrl(baseUrl, endpoint) {
  let base = String(baseUrl || "").trim().replace(/\/+$/, "");
  if (!base) return "";
  if (base.toLowerCase().endsWith(`/${endpoint.toLowerCase()}`)) return base;
  if (endpoint === "models" && base.toLowerCase().endsWith("/chat/completions")) {
    base = base.slice(0, -"/chat/completions".length);
  }
  const hasVersionSuffix = /\/v\d+(?:beta)?$/i.test(base);
  return `${base}${hasVersionSuffix ? "" : "/v1"}/${endpoint}`.replaceAll("/v1/v1", "/v1");
}

async function loadUndici() {
  try {
    return await import("undici");
  } catch {}

  const roots = [];
  if (process.env.NODE_PATH) roots.push(...process.env.NODE_PATH.split(path.delimiter));
  try {
    const root = execFileSync("npm", ["root", "-g"], {
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    }).trim();
    if (root) roots.push(root);
  } catch {}

  for (const root of roots.filter(Boolean)) {
    try {
      const candidate = path.join(root, "undici");
      const requireFromRoot = createRequire(path.join(root, "xu-undici-loader.cjs"));
      return requireFromRoot(candidate);
    } catch {}
  }
  return null;
}

async function maybeInstallProxyDispatcher() {
  const proxy = currentProxyFromEnv();
  if (!proxy) return;

  const undici = await loadUndici();
  if (!undici?.ProxyAgent || !undici?.setGlobalDispatcher) return;
  undici.setGlobalDispatcher(new undici.ProxyAgent(proxy));
}

async function fetchModelIds(baseUrl, apiKey) {
  const url = endpointUrl(baseUrl, "models");
  if (!url || !apiKey || typeof fetch !== "function") return [];
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 12000);
  try {
    const response = await fetch(url, {
      headers: { authorization: `Bearer ${apiKey}` },
      signal: controller.signal,
    });
    if (!response.ok) return [];
    const json = await response.json();
    const data = Array.isArray(json?.data) ? json.data : Array.isArray(json?.models) ? json.models : [];
    return [
      ...new Set(
        data
          .map((item) => (typeof item === "string" ? item : item?.id || item?.name || item?.model))
          .filter((id) => typeof id === "string" && id.trim())
          .map((id) => id.trim()),
      ),
    ].slice(0, 80);
  } catch {
    return [];
  } finally {
    clearTimeout(timer);
  }
}

function readJson(file, fallback) {
  try {
    return JSON.parse(fs.readFileSync(file, "utf8").replace(/^\uFEFF/, ""));
  } catch {
    return fallback;
  }
}

function writePrivate(file, content) {
  ensureDir(path.dirname(file));
  fs.writeFileSync(file, content);
  try {
    fs.chmodSync(file, 0o600);
  } catch {}
}

function preservedProjectConfig(target) {
  if (!fs.existsSync(target)) return "";
  const existing = fs.readFileSync(target, "utf8");
  const match = existing.match(/(?:^|\n)(\[projects\.[\s\S]*)$/);
  return match ? `\n${match[1].trim()}\n` : "";
}

function upsertEnv(file, key, value) {
  ensureDir(path.dirname(file));
  const line = `export ${key}=${JSON.stringify(value)}`;
  const existing = fs.existsSync(file) ? fs.readFileSync(file, "utf8").split(/\r?\n/) : [];
  const prefix = `export ${key}=`;
  const next = [];
  let replaced = false;
  for (const item of existing) {
    if (!item.trim()) continue;
    if (item.startsWith(prefix)) {
      next.push(line);
      replaced = true;
    } else {
      next.push(item);
    }
  }
  if (!replaced) next.push(line);
  writePrivate(file, `${next.join("\n")}\n`);
}

function installEmbeddedTools() {
  if (!embeddedTools) return;
  ensureDir(binDir);
  const tools = [
    ["codex-chat2responses-proxy.mjs", embeddedTools.proxy],
    ["generate-codex-model-catalog.mjs", embeddedTools.catalog],
  ];
  for (const [name, content] of tools) {
    if (!content) continue;
    const target = path.join(binDir, name);
    fs.writeFileSync(target, Buffer.from(content, "base64").toString("utf8"));
    try {
      fs.chmodSync(target, 0o755);
    } catch {}
  }
}

function writeCodexConfig({ target, providerId, providerName, apiKind, baseUrl, model, catalogPath, envKey, settings }) {
  const providerKey = apiKind === "responses" ? `${providerId}_responses` : `${providerId}_chat_proxy`;
  const lines = [
    `sandbox_mode = "danger-full-access"`,
    `approval_policy = "never"`,
    "",
    `model = ${tomlString(model)}`,
    `model_provider = ${tomlString(providerKey)}`,
  ];

  if (settings) lines.push(`model_context_window = ${settings.context}`);
  if (catalogPath) lines.push(`model_catalog_json = ${tomlString(catalogPath)}`);

  lines.push("");
  lines.push(`[model_providers.${providerKey}]`);
  lines.push(`name = ${tomlString(providerName)}`);
  lines.push(`base_url = ${tomlString(baseUrl)}`);
  if (apiKind === "responses") {
    lines.push(`env_key = ${tomlString(envKey)}`);
  } else {
    lines.push(`experimental_bearer_token = "local-proxy"`);
  }
  lines.push(`wire_api = "responses"`);
  if (settings) {
    lines.push(`request_timeout_ms = ${settings.timeoutSeconds * 1000}`);
    lines.push(`max_retries = ${settings.maxRetries}`);
  }

  ensureDir(path.dirname(target));
  fs.writeFileSync(target, `${lines.join("\n")}\n`);
  return providerKey;
}

function writeBaseConfigIfMissing() {
  ensureDir(codexHome);
  const base = path.join(codexHome, "config.toml");
  if (!fs.existsSync(base)) {
