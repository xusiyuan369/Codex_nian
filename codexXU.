function loadProvidersConfig() {
  const config = readJson(chatProvidersPath, { provider: {} });
  config.provider ||= config.providers || {};
  delete config.providers;
  return config;
}

function saveProvidersConfig(config) {
  config.provider ||= {};
  writePrivate(chatProvidersPath, `${JSON.stringify(config, null, 2)}\n`);
}

function upsertProvider({ providerId, providerName, apiKind, baseUrl, apiKey, models, settings }) {
  const opts = settings || DEFAULT_SETTINGS;
  const config = loadProvidersConfig();
  config.provider[providerId] = {
    apiKind,
    name: providerName,
    options: {
      baseURL: baseUrl,
      apiKey,
      timeout: opts.timeoutSeconds * 1000,
      chunkTimeout: opts.timeoutSeconds * 1000,
      maxRetries: opts.maxRetries,
      maxOutputTokens: opts.output,
    },
    models: Object.fromEntries(
      models.map((model) => [
        model,
        {
          name: model,
          limit: { context: opts.context, output: opts.output },
        },
      ]),
    ),
  };
  saveProvidersConfig(config);
}

function upsertChatProvider({ providerId, providerName, baseUrl, apiKey, models, settings }) {
  upsertProvider({ providerId, providerName, apiKind: "chat", baseUrl, apiKey, models, settings });
}

function removeProviderFromRegistry(providerId) {
  const config = loadProvidersConfig();
  if (!config.provider[providerId]) return;
  delete config.provider[providerId];
  saveProvidersConfig(config);
}

function removeEnv(file, key) {
  if (!fs.existsSync(file)) return;
  const prefix = `export ${key}=`;
  const next = fs
    .readFileSync(file, "utf8")
    .split(/\r?\n/)
    .filter((line) => line.trim() && !line.startsWith(prefix));
  writePrivate(file, next.length ? `${next.join("\n")}\n` : "");
}

