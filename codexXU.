function generateCatalog(providerId, providerName, models, settings) {
  const opts = settings || DEFAULT_SETTINGS;
  const generator = path.join(binDir, "generate-codex-model-catalog.mjs");
  if (!fs.existsSync(generator)) {
    warn("generate-codex-model-catalog.mjs not found in ~/bin; skipped model catalog generation.");
    return null;
  }

  const tmpDir = path.join(codexHome, "tmp");
  const catalogDir = path.join(codexHome, "model-catalogs");
  ensureDir(tmpDir);
  ensureDir(catalogDir);

  const bundledPath = path.join(tmpDir, "debug-models-bundled.json");
  const specPath = path.join(tmpDir, `${providerId}-models.json`);
  const outPath = path.join(catalogDir, `${providerId}-catalog.json`);

  try {
    const bundled = execFileSync("codex", ["debug", "models", "--bundled"], {
      encoding: "utf8",
      stdio: ["ignore", "pipe", "pipe"],
    });
    fs.writeFileSync(bundledPath, bundled);
  } catch (error) {
    warn(`Could not export bundled Codex model catalog: ${error.message}`);
    return null;
  }

  const spec = {
    models: models.map((model, index) => ({
      slug: model,
      display_name: model,
      description: `${model} routed through ${providerName}.`,
      context_window: opts.context,
      max_context_window: opts.context,
      output_limit: opts.output,
      priority: index,
      reasoning: false,
    })),
  };
  fs.writeFileSync(specPath, `${JSON.stringify(spec, null, 2)}\n`);

  try {
    execFileSync("node", [generator, "--spec", specPath, "--out", outPath, "--template", bundledPath], {
      stdio: "ignore",
    });
    return path.relative(codexHome, outPath).replace(/\\/g, "/");
  } catch (error) {
    warn(`Could not generate model catalog: ${error.message}`);
    return null;
  }
}

function generateMultiCatalog(providers, catalogName = "xucodex") {
  const generator = path.join(binDir, "generate-codex-model-catalog.mjs");
  if (!fs.existsSync(generator)) {
    warn("generate-codex-model-catalog.mjs not found in ~/bin; skipped model catalog generation.");
    return null;
  }

  const entries = [];
  for (const provider of providers) {
    const opts = provider.settings || DEFAULT_SETTINGS;
    for (const model of provider.models || []) {
      entries.push({
        model,
        providerId: provider.providerId,
        providerName: provider.providerName,
        publicModel: `${model}_${provider.providerId}`,
        settings: opts,
      });
    }
  }
  if (!entries.length) return null;

  const tmpDir = path.join(codexHome, "tmp");
  const catalogDir = path.join(codexHome, "model-catalogs");
  ensureDir(tmpDir);
  ensureDir(catalogDir);

  const bundledPath = path.join(tmpDir, "debug-models-bundled.json");
  const specPath = path.join(tmpDir, `${catalogName}-models.json`);
  const outPath = path.join(catalogDir, `${catalogName}-catalog.json`);

  try {
    const bundled = execFileSync("codex", ["debug", "models", "--bundled"], {
      encoding: "utf8",
      stdio: ["ignore", "pipe", "pipe"],
    });
    fs.writeFileSync(bundledPath, bundled);
  } catch (error) {
    warn(`Could not export bundled Codex model catalog: ${error.message}`);
    return null;
  }

  const spec = {
    models: entries.map((entry, index) => ({
      slug: entry.publicModel,
      display_name: entry.publicModel,
      description: `${entry.model} routed through ${entry.providerName}.`,
      context_window: entry.settings.context,
      max_context_window: entry.settings.context,
      output_limit: entry.settings.output,
      priority: index,
      reasoning: false,
    })),
  };
  fs.writeFileSync(specPath, `${JSON.stringify(spec, null, 2)}\n`);

  try {
    execFileSync("node", [generator, "--spec", specPath, "--out", outPath, "--template", bundledPath], {
      stdio: "ignore",
    });
    return path.relative(codexHome, outPath).replace(/\\/g, "/");
  } catch (error) {
    warn(`Could not generate model catalog: ${error.message}`);
    return null;
  }
}

function writeUnifiedCodexConfig({
  target,
  providerKey,
  providerName,
  providers,
  catalogPath,
  proxyPort = readProxyPort(),
}) {
  const firstModel = providers.flatMap((provider) =>
    (provider.models || []).map((model) => `${model}_${provider.providerId}`),
  )[0];
  if (!firstModel) throw new Error("至少需要一个模型。");

  const lines = [
    `sandbox_mode = "danger-full-access"`,
    `approval_policy = "never"`,
    "",
    `model = ${tomlString(firstModel)}`,
    `model_provider = ${tomlString(providerKey)}`,
  ];
  if (catalogPath) lines.push(`model_catalog_json = ${tomlString(catalogPath)}`);
  lines.push("");
  lines.push(`[model_providers.${providerKey}]`);
  lines.push(`name = ${tomlString(providerName)}`);
  lines.push(`base_url = ${tomlString(proxyBaseUrl(proxyPort))}`);
  lines.push(`experimental_bearer_token = "local-proxy"`);
  lines.push(`wire_api = "responses"`);
  lines.push(`request_timeout_ms = ${Math.max(...providers.map((p) => p.settings.timeoutSeconds)) * 1000}`);
  lines.push(`max_retries = ${Math.max(...providers.map((p) => p.settings.maxRetries))}`);

  ensureDir(path.dirname(target));
  fs.writeFileSync(target, `${lines.join("\n")}\n${preservedProjectConfig(target)}`);
  return target;
}

function writeMultiCodexConfig({ providers, catalogPath, proxyPort = readProxyPort() }) {
  const profileTarget = writeUnifiedCodexConfig({
    target: path.join(codexHome, "xucodex.config.toml"),
    providerKey: "xucodex_multi",
    providerName: "XuCodex Multi Provider",
    providers,
    catalogPath,
    proxyPort,
  });
  const defaultTarget = writeUnifiedCodexConfig({
    target: path.join(codexHome, "config.toml"),
    providerKey: "xucodex_multi",
    providerName: "XuCodex Multi Provider",
    providers,
    catalogPath,
    proxyPort,
  });
  return defaultTarget || profileTarget;
}

function apiKindLabel(apiKind) {
  return apiKind === "responses" ? "Responses API" : "Chat Completions 转 Responses";
}

function providerFromRegistry(providerId, entry = {}) {
  const options = entry.options || {};
  const models = Object.keys(entry.models || {});
  const firstModel = models[0] ? entry.models[models[0]] : null;
  const timeoutMs = positiveInteger(options.timeout, options.chunkTimeout, DEFAULT_SETTINGS.timeoutSeconds * 1000);
  return {
    providerId,
    providerName: entry.name || providerId,
    apiKind: entry.apiKind || entry.api_kind || options.apiKind || "chat",
    baseUrl: options.baseURL || entry.baseURL || "",
    apiKey: options.apiKey || entry.apiKey || "",
    models,
    settings: {
      context: positiveInteger(firstModel?.limit?.context, DEFAULT_SETTINGS.context),
      output: positiveInteger(options.maxOutputTokens, firstModel?.limit?.output, DEFAULT_SETTINGS.output),
      timeoutSeconds: positiveInteger(Math.round(timeoutMs / 1000), DEFAULT_SETTINGS.timeoutSeconds),
      maxRetries: positiveInteger(options.maxRetries, DEFAULT_SETTINGS.maxRetries),
    },
  };
}

function listRegisteredProviders() {
  const config = loadProvidersConfig();
  return Object.entries(config.provider || {}).map(([providerId, entry]) =>
    providerFromRegistry(providerId, entry),
  );
}

async function askSecretMaybeKeep(current = "") {
  if (!current) return askSecret("API key");
  const sentinel = "__KEEP_EXISTING_KEY__";
  const prompt = "API key（直接回车保留原 key）";
  if (!isTty || !process.stdin.setRawMode) {
    const value = await ask(prompt, sentinel);
    return value === sentinel ? current : value;
  }
  const value = await readLineRaw(prompt, sentinel, { secret: true, allowBack: true });
  if (isBack(value)) return BACK;
  return value === sentinel ? current : value;
}

async function collectProviderDetails(existing = null) {
  const state = {
    apiKind: existing?.apiKind || "responses",
    providerName: existing?.providerName || "provider",
    baseUrl: existing?.baseUrl || "",
    apiKey: existing?.apiKey || "",
    models: existing?.models || [],
    settings: { ...(existing?.settings || DEFAULT_SETTINGS) },
  };
  const apiKindOptions = [
    { label: "Responses API 直连", value: "responses" },
    { label: "Chat Completions 转 Responses API", value: "chat" },
  ];
  let step = 0;

  while (step < 6) {
    if (step === 0) {
      const value = await choose("选择这个供应商的协议格式", apiKindOptions, {
        note: "每个供应商单独选择协议；后续可在管理页编辑。",
      });
      if (isBack(value)) return BACK;
      state.apiKind = value;
      step = 1;
      continue;
    }

    if (step === 1) {
      if (state.apiKind === "chat" && !fs.existsSync(proxyPortPath)) {
        const port = await configureProxyPort();
        if (isBack(port)) {
          step = 0;
          continue;
        }
      }
      const value = await ask("供应商名称", state.providerName || "provider");
      if (isBack(value)) {
        step = 0;
        continue;
      }
      state.providerName = value;
      step = 2;
      continue;
    }

    if (step === 2) {
      const fallback =
        state.baseUrl ||
        (state.apiKind === "responses" ? "https://api.openai.com/v1" : "https://api.example.com/v1");
      const value = await ask("Base URL", fallback);
      if (isBack(value)) {
        step = 1;
        continue;
      }
      state.baseUrl = value;
      step = 3;
      continue;
    }

    if (step === 3) {
      const value = await askSecretMaybeKeep(state.apiKey);
      if (isBack(value)) {
        step = 2;
        continue;
      }
      state.apiKey = value;
      step = 4;
      continue;
    }

    if (step === 4) {
      let modelIds = [];
      if (state.apiKey) {
        const fetchedModels = await fetchModelIds(state.baseUrl, state.apiKey);
        if (fetchedModels.length) {
          const selected = await chooseMany(
            "检测到上游模型列表，请选择要写入 Codex 的模型",
            fetchedModels.map((id) => ({ label: id, value: id })),
          );
          if (isBack(selected)) {
            step = 3;
            continue;
          }
          modelIds = selected;
        } else {
          warn("没有自动获取到模型列表，将改为手动输入模型 ID。");
        }
      }

      const modelInput = modelIds.length
        ? modelIds.join(",")
        : await ask(
            "模型 ID，多个用英文逗号分隔",
            state.models.length ? state.models.join(",") : state.apiKind === "chat" ? "model-name" : "gpt-5.5",
          );
      if (isBack(modelInput)) {
        step = 3;
        continue;
      }
      state.models = modelInput
        .split(",")
        .map((model) => model.trim())
        .filter(Boolean);
      step = 5;
      continue;
    }

    if (step === 5) {
      const action = await waitForConfirmOrAdvanced(state.settings);
      if (isBack(action)) {
        step = 4;
        continue;
      }
      if (action === "advanced") {
        const nextSettings = await configureAdvancedSettings(state.settings);
        if (!isBack(nextSettings)) state.settings = nextSettings;
        continue;
      }
      step = 6;
    }
  }

  const providerId = safeId(state.providerName);
  if (!state.models.length) throw new Error("至少需要一个模型 ID。");
  if (!state.apiKey) warn("API key 为空。配置会写入，但补上 key 之前供应商不能正常工作。");
  return {
    providerId,
    providerName: state.providerName,
    apiKind: state.apiKind,
    baseUrl: state.baseUrl,
    apiKey: state.apiKey,
    models: state.models,
    settings: state.settings,
  };
}

function rebuildMultiProviderProfile() {
  const providers = listRegisteredProviders();
  if (!providers.length) {
    warn("当前还没有供应商。先添加一个供应商。");
    return null;
  }
  const catalogPath = generateMultiCatalog(providers);
  const proxyPort = readProxyPort();
  const targetConfig = writeMultiCodexConfig({ providers, catalogPath, proxyPort });
  return { providers, catalogPath, targetConfig };
}

function rebuildSingleProviderProfile(provider) {
  const proxyPort = readProxyPort();
  const catalogPath = generateMultiCatalog([provider], `single-${provider.providerId}`);
  const targetConfig = writeUnifiedCodexConfig({
    target: path.join(codexHome, "config.toml"),
    providerKey: `${provider.providerId}_xu_single`,
    providerName: `${provider.providerName} via XuCodex`,
    providers: [provider],
    catalogPath,
    proxyPort,
  });
  return { provider, catalogPath, targetConfig };
}

function saveMultiProvider(provider, oldProviderId = null) {
  if (oldProviderId && oldProviderId !== provider.providerId) {
    removeProviderFromRegistry(oldProviderId);
    removeEnv(path.join(codexHome, "xu-env.sh"), envName(oldProviderId));
  }
  upsertProvider(provider);
  const result = rebuildMultiProviderProfile();

  title("完成");
  ok(`已保存供应商: ${provider.providerName} (${apiKindLabel(provider.apiKind)})`);
  ok(`已写入供应商清单: ${chatProvidersPath}`);
  if (result?.targetConfig) ok(`已重建统一 profile: ${result.targetConfig}`);
  if (result?.catalogPath) ok(`已重建模型目录: ${result.catalogPath}`);
  console.log("");
  console.log("运行统一多供应商入口: codex");
  console.log("在 Codex 模型列表里选择形如: 模型名_供应商");
}

async function confirmDelete(provider) {
  const value = await choose(`确认删除供应商 ${provider.providerName}？`, [
    { label: "取消", value: "cancel" },
    { label: "删除", value: "delete" },
  ], { note: "只删除 XuCodex 供应商清单，不会修改 opencode。" });
  return value === "delete";
}

async function manageExistingProvider(provider) {
  for (;;) {
    const value = await choose(`管理供应商：${provider.providerName}`, [
      { label: "编辑这个供应商", value: "edit" },
      { label: "删除这个供应商", value: "delete" },
      { label: "返回", value: "back" },
    ], { note: "Tab/↑↓ 移动，Enter 确认当前操作。" });
    if (isBack(value) || value === "back") return;
    if (value === "edit") {
      const next = await collectProviderDetails(provider);
      if (isBack(next)) continue;
      saveMultiProvider(next, provider.providerId);
      return;
    }
    if (value === "delete") {
      if (!(await confirmDelete(provider))) continue;
      removeProviderFromRegistry(provider.providerId);
      removeEnv(path.join(codexHome, "xu-env.sh"), envName(provider.providerId));
      rebuildMultiProviderProfile();
      ok(`已删除供应商: ${provider.providerName}`);
      return;
    }
  }
}

async function runMultiProviderManager() {
  if (!fs.existsSync(proxyPortPath)) {
    const port = await configureProxyPort();
    if (isBack(port)) return;
  }
  for (;;) {
    const providers = listRegisteredProviders();
    const providerOptions = providers.map((provider) => ({
      label:
        `${provider.providerName} · ${apiKindLabel(provider.apiKind)} · ` +
        `${provider.models.map((model) => `${model}_${provider.providerId}`).join(", ")}`,
      value: provider.providerId,
    }));
    const value = await choose(
      "多供应商管理：Tab/↑↓ 选中，Enter 管理；保存后 Codex 模型显示为 模型名_供应商",
      [
        { label: "添加供应商", value: "__add__", description: "新增会追加到清单，不会覆盖已有供应商。" },
        { label: `设置本地代理端口（当前 ${readProxyPort()}）`, value: "__port__", description: "用于统一入口和 Chat 转换代理。" },
        { label: "设置上游网络/代理", value: "__upstream_proxy__", description: "可选择直连、跟随环境变量，或保存 HTTP 代理地址。" },
        { label: "重新生成统一模型列表", value: "__rebuild__", description: "把所有模型刷新成 模型名_供应商。" },
        ...providerOptions,
        { label: "退出", value: "__exit__" },
      ],
      {
        backLabel: "Esc 退出",
        note: "Tab/↑↓ 移动，Enter 确认；模型列表页可用 Space 多选。",
      },
    );
    if (isBack(value) || value === "__exit__") return;
    if (value === "__add__") {
      const provider = await collectProviderDetails();
      if (!isBack(provider)) saveMultiProvider(provider);
      if (!isTty) return;
      continue;
    }
    if (value === "__port__") {
      const port = await configureProxyPort({ forceAsk: true });
      if (!isBack(port)) rebuildMultiProviderProfile();
      if (!isTty) return;
      continue;
    }
    if (value === "__upstream_proxy__") {
      await configureUpstreamProxy();
      if (!isTty) return;
      continue;
    }
    if (value === "__rebuild__") {
      const result = rebuildMultiProviderProfile();
      if (result?.targetConfig) {
        ok(`已重建统一 profile: ${result.targetConfig}`);
        console.log("运行: codex");
      }
      if (!isTty) return;
      continue;
    }
    const provider = providers.find((item) => item.providerId === value);
    if (provider) await manageExistingProvider(provider);
  }
}

async function runSingleProviderWizard() {
  if (!fs.existsSync(proxyPortPath)) {
    const port = await configureProxyPort();
    if (isBack(port)) return;
  }
  for (;;) {
    const providers = listRegisteredProviders();
    if (!providers.length) {
      warn("当前还没有供应商。先添加一个供应商。");
      const provider = await collectProviderDetails();
      if (isBack(provider)) return;
      saveMultiProvider(provider);
      if (!isTty) {
        const result = rebuildSingleProviderProfile(provider);
        ok(`已生成单供应商配置: ${result.targetConfig}`);
        return;
      }
      continue;
    }

    const value = await choose(
      "单供应商：Tab/↑↓ 选中，Enter 生成只包含该供应商的 Codex 模型列表",
      [
        { label: "添加供应商", value: "__add__", description: "添加后仍保存在同一份供应商清单里。" },
        ...providers.map((provider) => ({
          label:
            `${provider.providerName} · ${apiKindLabel(provider.apiKind)} · ` +
            `${provider.models.map((model) => `${model}_${provider.providerId}`).join(", ")}`,
          value: provider.providerId,
        })),
        { label: "返回", value: "__back__" },
      ],
      { note: "单供应商也来自同一份列表，模型同样显示为 模型名_供应商。" },
    );
    if (isBack(value) || value === "__back__") return;
    if (value === "__add__") {
      const provider = await collectProviderDetails();
      if (!isBack(provider)) saveMultiProvider(provider);
      if (!isTty) return;
      continue;
    }
    const provider = providers.find((item) => item.providerId === value);
    if (!provider) continue;
    const result = rebuildSingleProviderProfile(provider);
    title("完成");
    ok(`已生成单供应商配置: ${result.targetConfig}`);
    if (result.catalogPath) ok(`已生成模型目录: ${result.catalogPath}`);
    console.log("");
    console.log("运行: codex");
    console.log(`Codex 模型列表会显示: ${provider.models.map((model) => `${model}_${provider.providerId}`).join(", ")}`);
    return;
  }
}

async function runWizard() {
  for (;;) {
    const providerModeOptions = [
      {
        label: "单供应商",
        value: "single",
        description: "只启用一个供应商；Codex 模型列表只显示它的模型。",
      },
      {
        label: "多供应商",
        value: "multi",
        description: "启用供应商清单里的所有供应商；模型显示为 模型名_供应商。",
      },
      {
        label: "上游网络/代理设置",
        value: "upstream_proxy",
        description: "控制本地转发层出网：直连、跟随环境变量或固定代理地址。",
      },
    ];

    const providerMode = await choose("选择供应商模式", providerModeOptions, {
      backLabel: "Esc 退出",
      note: "单/多供应商共用同一份供应商列表；保存后普通输入 codex 即可启动。",
    });
    if (isBack(providerMode)) {
      console.log("已退出。");
      return;
    }
    if (providerMode === "single") {
      await runSingleProviderWizard();
      return;
    }
    if (providerMode === "multi") {
      await runMultiProviderManager();
      return;
    }
    if (providerMode === "upstream_proxy") {
      await configureUpstreamProxy();
      if (!isTty) return;
      continue;
    }
  }
}

async function main() {
  title("XuCodex - Codex CLI 供应商配置");
  info("这个工具只写本机配置；API key 会留在当前 Termux 里。");

  ensureDir(codexHome);
  ensureDir(binDir);
  applySavedUpstreamProxy();
  await maybeInstallProxyDispatcher();
  installEmbeddedTools();
  writeBaseConfigIfMissing();
  installCodexWrapper();
  installCodexLauncher();
  await runWizard();
}

main()
  .catch((error) => {
    console.error(`\nERROR: ${error.message}`);
    process.exitCode = 1;
  })
  .finally(() => {
    rl?.close();
  });
